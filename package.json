{
  "name": "backstage",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tw:build": "tailwindcss -i src/styles.css -o src/styles.built.css",
    "tw:watch": "tailwindcss -i src/styles.css -o src/styles.built.css --watch",
    "prestart": "npm run tw:build",
    "start": "npm run tw:watch & ng serve",
    "prebuild": "npm run tw:build",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/cli": "^4.2.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
